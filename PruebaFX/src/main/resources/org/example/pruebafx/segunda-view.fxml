<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pruebafx.SegundoController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" />
   <Button fx:id="AtrasButton" mnemonicParsing="false" text="Atras" />
   <Label fx:id="welcomeText1" text="Mantenimiento de Personas" textFill="#0e80eb" />
   <TableView fx:id="PersonasTableView" prefHeight="200.0" prefWidth="200.0">
     <columns>
       <TableColumn fx:id="nombreTableColumn" prefWidth="75.0" text="Nombre" />
       <TableColumn fx:id="edadTableColumn" prefWidth="75.0" text="Edad" />
     </columns>
      <columnResizePolicy>
         <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
      </columnResizePolicy>
   </TableView>
   <Label fx:id="nombreLabel" text="nombre" />
   <TextField fx:id="nombreTextField" promptText="Introduce nombre" />
   <Label fx:id="edadLabel" text="Edad" />
   <TextField fx:id="edadTextField" promptText="Introduce edad" />
   <Button  mnemonicParsing="false" onAction="#guardarButton" text="Guardar" />
</VBox>
