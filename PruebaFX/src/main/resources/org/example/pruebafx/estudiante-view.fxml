<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pruebafx.EstudianteController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" />
    <Label fx:id="welcomeText1" text="Mantenimiento de Estudiantes" textFill="#0e80eb" />

    <TableView fx:id="tablaEstudiantes" prefHeight="200.0" prefWidth="200.0">
        <columns>
            <TableColumn fx:id="columnaNia" prefWidth="75.0" text="NIA" />
            <TableColumn fx:id="columnaNombre" prefWidth="75.0" text="Nombre" />
            <TableColumn fx:id="columnaFechaNac" prefWidth="75.0" text="Fecha nacimiento" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER" spacing="10.0">
        <Button mnemonicParsing="false" onAction="#clickEditar" text="Editar" />
        <Button mnemonicParsing="false" onAction="#clickEliminar" text="Eliminar" />
    </HBox>

    <Label fx:id="niaLabel" text="NIA" />
    <TextField fx:id="niaTextField" promptText="Introduce NIA" />

    <Label fx:id="nombreLabel" text="Nombre" />
    <TextField fx:id="nombreTextField" promptText="Introduce nombre" />

    <Label fx:id="fechaLabel" text="Fecha de Nacimiento" />
    <DatePicker fx:id="fechaNacPicker" promptText="Selecciona fecha" />

    <HBox alignment="CENTER" spacing="10.0">
        <Button fx:id="botonInsertar" mnemonicParsing="false" onAction="#clickInsertar" text="Insertar" />
        <Button fx:id="botonGuardar" mnemonicParsing="false" onAction="#clickGuardar" text="Guardar" />
    </HBox>
</VBox>