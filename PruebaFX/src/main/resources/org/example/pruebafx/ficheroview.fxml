<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.pruebafx.GestorFicherosController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Gestor de Ficheros" style="-fx-font-size: 18px; -fx-font-weight: bold;" textFill="#0e80eb" />

    <TextField fx:id="nombreBaseField" promptText="Nombre del archivo (ej: datos)" />
    <TextField fx:id="cantidadField" promptText="Cantidad de archivos a crear" />

    <HBox spacing="10" alignment="CENTER">
        <Button text="Generar Archivos" onAction="#ejecutarGenerar" />
        <Button text="Listar .txt" onAction="#ejecutarListar" />
    </HBox>

    <Separator />

    <TextField fx:id="palabraBusquedaField" promptText="Palabra a buscar" />
    <Button text="Contar Palabra" onAction="#ejecutarContar" />

    <Button text="Volver" onAction="#atrasClickButton" />
</VBox>